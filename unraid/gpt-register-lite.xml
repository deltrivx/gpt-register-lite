<?xml version="1.0"?>
<Container version="2">
  <Name>gpt-register-lite</Name>
  <Repository>gpt-register-lite:local</Repository>
  <Registry/>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/deltrivx/gpt-register-lite</Support>
  <Project>https://github.com/deltrivx/gpt-register-lite</Project>
  <Overview>ChatGPT protocol register (lite) WebUI. CF temp mail via gpt-mail-worker on deltrivx.ccwu.cc. Does not affect Grok mail on deltrivx.com.</Overview>
  <Category>Tools:Utilities Productivity:</Category>
  <WebUI>http://[IP]:[PORT:8765]/</WebUI>
  <TemplateURL/>
  <Icon>https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/chatgpt.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>Build image first: git clone private repo on Unraid host, then docker build -t gpt-register-lite:local .</Requires>
  <Config Name="WebUI Port" Target="8765" Default="8765" Mode="tcp" Description="WebUI port" Type="Port" Display="always" Required="true" Mask="false">8765</Config>
  <Config Name="Appdata" Target="/data" Default="/mnt/user/appdata/gpt-register-lite" Mode="rw" Description="Persistent DB and logs" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/gpt-register-lite</Config>
  <Config Name="TZ" Target="TZ" Default="Asia/Shanghai" Mode="rw" Description="Timezone" Type="Variable" Display="always" Required="false" Mask="false">Asia/Shanghai</Config>
  <Config Name="HOST" Target="HOST" Default="0.0.0.0" Mode="rw" Description="Listen host" Type="Variable" Display="advanced" Required="false" Mask="false">0.0.0.0</Config>
  <Config Name="PORT" Target="PORT" Default="8765" Mode="rw" Description="Listen port" Type="Variable" Display="advanced" Required="false" Mask="false">8765</Config>
  <Config Name="DATA_DIR" Target="DATA_DIR" Default="/data" Mode="rw" Description="In-container data dir" Type="Variable" Display="advanced" Required="false" Mask="false">/data</Config>
  <Config Name="MAIL_SOURCE" Target="MAIL_SOURCE" Default="cf_temp" Mode="rw" Description="outlook or cf_temp" Type="Variable" Display="always" Required="true" Mask="false">cf_temp</Config>
  <Config Name="CF_API_URL" Target="CF_API_URL" Default="https://gpt-mail.deltrivx.ccwu.cc" Mode="rw" Description="gpt-mail-worker base URL" Type="Variable" Display="always" Required="true" Mask="false">https://gpt-mail.deltrivx.ccwu.cc</Config>
  <Config Name="CF_DOMAIN" Target="CF_DOMAIN" Default="deltrivx.ccwu.cc" Mode="rw" Description="Catch-all mail domain for GPT only" Type="Variable" Display="always" Required="true" Mask="false">deltrivx.ccwu.cc</Config>
  <Config Name="CF_ADMIN_TOKEN" Target="CF_ADMIN_TOKEN" Default="" Mode="rw" Description="Worker API_KEY / admin token (secret)" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="PROXY" Target="PROXY" Default="" Mode="rw" Description="Optional egress proxy e.g. http://192.168.31.10:7890" Type="Variable" Display="always" Required="false" Mask="false"></Config>
</Container>
