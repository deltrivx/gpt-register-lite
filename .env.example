# Copy to .env and fill secrets. NEVER commit .env

# WebUI
HOST=0.0.0.0
PORT=8765
TZ=Asia/Shanghai
DATA_DIR=/data

# Mail: CF temp email (gpt-mail-worker, zone deltrivx.ccwu.cc only)
# Grok keeps deltrivx.com + grok-mail-worker untouched.
MAIL_SOURCE=cf_temp
CF_API_URL=https://gpt-mail.deltrivx.ccwu.cc
CF_DOMAIN=deltrivx.ccwu.cc
CF_ADMIN_TOKEN=replace-with-worker-api-key

# Optional registration egress proxy (strongly recommended)
# PROXY=socks5://user:pass@host:port
# PROXY=http://192.168.31.10:7890
PROXY=

# Optional SMS (configure in WebUI if needed)
# SMS_ENABLED=0
